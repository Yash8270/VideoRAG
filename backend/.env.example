# ── Google Gemini (Required) ───────────────────────────────────────────────
GOOGLE_API_KEY=AIzaSyFakeKeyPlaceholderValue1234567890

# ── LLM / Embedding Models (Optional) ──────────────────────────────────────
LLM_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── ChromaDB (Optional) ────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=data/vectorstore
CHROMA_COLLECTION_NAME=rag_videos

# ── Text Chunking (Optional) ───────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── Application (Optional) ─────────────────────────────────────────────────
APP_NAME="VideoRAG API"
APP_VERSION=1.0.0
DEBUG=True

# ── CORS ───────────────────────────────────────────────────────────────────
# Use comma-separated origins if passing multiple (e.g., '["http://localhost:3000", "https://your-frontend.vercel.app"]')
ALLOWED_ORIGINS=["*"]
